# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Public site URL (used in sitemap.xml and robots.txt Sitemap directive)
NEXT_PUBLIC_SITE_URL=https://stellaredupay.example.com

# Stellar network environment. Set to 'testnet' to show the testnet warning banner.
# Leave unset or set to 'mainnet' for production — the banner will not appear.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
